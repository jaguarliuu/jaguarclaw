{
  "appId": "com.local.miniclaw",
  "productName": "MiniClaw",
  "directories": {
    "output": "dist"
  },
  "files": [
    "**/*",
    "!dist/**",
    "!release/**"
  ],
  "extraResources": [
    {
      "from": "assets/icon-local.png",
      "to": "icon.png"
    },
    {
      "from": "resources/jre",
      "to": "jre"
    },
    {
      "from": "resources/app.jar",
      "to": "app.jar"
    },
    {
      "from": "resources/webapp",
      "to": "webapp"
    },
    {
      "from": "resources/skills",
      "to": "skills"
    }
  ],
  "win": {
    "target": "nsis",
    "icon": "assets/icon-local.ico",
    "executableName": "miniclaw"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "perMachine": true,
    "createDesktopShortcut": "always",
    "createStartMenuShortcut": true,
    "shortcutName": "MiniClaw",
    "deleteAppDataOnUninstall": true
  },
  "mac": {
    "target": "dmg",
    "icon": "assets/icon-local.png",
    "identity": null
  },
  "publish": {
    "provider": "github",
    "owner": "jaguarliuu",
    "repo": "jaguarclaw",
    "tagNamePrefix": "local-v"
  },
  "extraMetadata": {
    "name": "miniclaw",
    "productName": "MiniClaw"
  }
}
